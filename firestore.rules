rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'displayName', 'email']) &&
        request.resource.data.uid == request.auth.uid;
    }

    // Meetings collection
    match /meetings/{meetingId} {
      allow get: if isSignedIn();
      allow list: if false; // Meetings are joined via direct ID
      allow create: if isSignedIn() && isValidId(meetingId);
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      
      // Chat messages
      match /chat/{messageId} {
        allow list: if isSignedIn();
        allow create: if isSignedIn() && 
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text.size() <= 1000;
      }
      
      // WebRTC Calls (Signaling)
      match /calls/{callId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        
        match /offerCandidates/{candidateId} {
          allow read, write: if isSignedIn();
        }
        match /answerCandidates/{candidateId} {
          allow read, write: if isSignedIn();
        }
      }
    }
  }
}
